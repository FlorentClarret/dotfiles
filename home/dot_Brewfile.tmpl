{{- $brewConfig := .packages.macos.brew -}}
{{- $brews := $brewConfig.brews.base -}}
{{- $casks := $brewConfig.casks.base -}}

{{- if .personal -}}
{{-   $brews = concat $brews $brewConfig.brews.personal -}}
{{-   $casks = concat $casks $brewConfig.casks.personal -}}
{{- end -}}

{{- if .work -}}
{{-   $brews = concat $brews $brewConfig.brews.work -}}
{{-   $casks = concat $casks $brewConfig.casks.work -}}
{{- end -}}

{{ range ($brews | sortAlpha | uniq) -}}
brew {{ . | quote }}
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask {{ . | quote }}
{{ end -}}
