[user]
    email = {{ .email.work }}
    signingkey = {{ onepasswordRead (print "op://private/MacBookPro M4/public key") $.email.work }}

[url "git@github-emu:ddoghq/"]
    insteadOf = git@github.com:ddoghq/

[url "git@github-emu:florent-clarret_ddog/"]
    insteadOf = git@github.com:florent-clarret_ddog/

[includeIf "gitdir:~/Documents/Perso/**"]
    path = .config/git/gitconfig-perso.toml

[includeIf "gitdir:~/.local/share/chezmoi/**"]
    path = .config/git/gitconfig-perso.toml
